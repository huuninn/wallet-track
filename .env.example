# ============================================================================
# Wallet Track — Environment Configuration
# ============================================================================
# Copie para `.env` e preencha todos os secrets.
# Variáveis sensíveis DEVEM ficar vazias neste arquivo (template).
# Em produção (Cloud Run), os secrets são injetados via Secret Manager (M10).
# ----------------------------------------------------------------------------

# --- App (Laravel) ---
APP_NAME="Wallet Track"
APP_ENV=local
APP_KEY=
# Gerar com: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file

# PHP CLI server workers (apenas para `php artisan serve`, não usado em prod)
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# --- Logging ---
# Em produção/Cloud Run usar "stderr" (JSON estruturado p/ Cloud Logging).
# Em dev local pode ser "stack" (arquivo em storage/logs/laravel.log).
LOG_CHANNEL=stderr
LOG_STACK=single
# ⚠️ Nível de log: o Nutgram (vendor) loga o payload BRUTO do update do Telegram
# em nível debug ("Update processed") e error ("Update failed"). Como é um bot
# financeiro, o payload contém valores/descrições de transações (PII).
# - Dev local: "debug" é OK (somente você vê seus próprios dados).
# - PRODUÇÃO: usar "info" ou superior para NÃO vazar payloads no Cloud Logging.
#   (O Dockerfile de produção já fixa LOG_LEVEL=info.)
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null
# Sobrescrever formato do stderr (default: JsonFormatter). Ex.: LineFormatter
# LOG_STDERR_FORMATTER=
# LOG_STDERR_STACKTRACES=false

# --- Database ---
# SQLite por padrão (sem BD relacional no projeto — fonte de verdade é Firestore).
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# --- Session / Cache / Queue ---
# Sessões e cache via banco (sqlite) em dev. Em prod, o estado vive no Firestore.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (não utilizado pelo bot; mantido pelo skeleton) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS (não utilizado; mantido pelo skeleton) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================================
# Telegram
# ============================================================================
# Token obtido com @BotFather no Telegram.
TELEGRAM_BOT_TOKEN=
# Secret token para validar a origem do webhook (gerar localmente):
#   openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET_TOKEN=
# Lista de chat_ids autorizados (whitelist, uso pessoal). Separar por vírgula.
# Ex.: TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_ALLOWED_CHAT_IDS=
# URL pública do webhook (definida após deploy no Cloud Run ou ngrok em dev).
# Ex.: https://wallet-track-xxxxxx-rj.a.run.app/webhook/telegram
TELEGRAM_WEBHOOK_URL=

# ============================================================================
# DeepSeek (extração de texto → JSON)
# ============================================================================
# Obter em: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============================================================================
# Gemini (OCR multimodal de notas fiscais → JSON)
# ============================================================================
# Obter em (AI Studio): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# Google Cloud (Firestore + Sheets)
# ============================================================================
# Project ID do GCP onde Firestore e Sheets residem.
GOOGLE_CLOUD_PROJECT_ID=
# Database ID do Firestore (Native mode). Se usar o (default), deixar vazio.
# Nota: o projeto foi provisionado com um banco nomeado em Native mode porque o
# (default) acabou criado em Datastore mode (incompatível com google/cloud-firestore).
FIRESTORE_DATABASE_ID=
# Em desenvolvimento local: caminho absoluto para o JSON da Service Account.
# Em produção (M10): injetado via Secret Manager (não usar este caminho).
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
# Alternativa: conteúdo JSON da Service Account em base64 (usado em prod).
# GOOGLE_SERVICE_ACCOUNT_JSON=
# ID da planilha (extraído da URL: /d/<ID>/edit).
GOOGLE_SHEETS_SPREADSHEET_ID=
# Nome da aba principal da planilha.
GOOGLE_SHEETS_SHEET_NAME=Transações
# Nome da aba auxiliar de categorias (sync best-effort a partir do Firestore).
GOOGLE_SHEETS_CATEGORIES_SHEET_NAME=Categorias

# ============================================================================
# Regras de negócio (decisões das Clarificações)
# ============================================================================
# Máximo de tentativas de sync pendente (Sheets) antes de marcar como failed.
SYNC_MAX_RETRIES=3
# Tempo máximo de uma sessão de conversação (minutos) antes de expirar.
SESSION_TIMEOUT_MINUTES=15

# ============================================================================
# Cron (Cloud Scheduler → /cron/sync-pending, implementado em M9)
# ============================================================================
# Token secreto validado no header X-Cron-Token. Gerar com: openssl rand -hex 32
CRON_SECRET_TOKEN=

# ============================================================================
# Vite / Frontend (skeleton)
# ============================================================================
VITE_APP_NAME="${APP_NAME}"

# ============================================================================
# Telescope (apenas em ambiente local — ver TELESCOPE_ALLOWED_IPS)
# ============================================================================
# Master switch: liga/desliga o Telescope independentemente do ambiente.
# Em produção/staging NUNCA deve estar true (mesmo com APP_ENV=local).
TELESCOPE_ENABLED=false

# Driver de storage (atualmente apenas 'database' é suportado).
TELESCOPE_DRIVER=database

# Conexão de banco dedicada para o Telescope (registrada em runtime no
# TelescopeServiceProvider; ver M3). NÃO alterar para 'mysql' etc.
TELESCOPE_DB_CONNECTION=telescope

# Whitelist de IPs com acesso ao painel /telescope (formato CSV).
# Vazio = usar defaults (127.0.0.1, ::1, ranges Docker 172.16/12, 192.168/16, 10/8).
# Para liberar IPs externos específicos (ex.: CI), listar aqui (sem ranges CIDR).
# Exemplo: TELESCOPE_ALLOWED_IPS=203.0.113.5,198.51.100.0/24
TELESCOPE_ALLOWED_IPS=
