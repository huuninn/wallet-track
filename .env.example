# ============================================================================
# Wallet Track — Environment Configuration
# ============================================================================
# Copie para `.env` e preencha todos os secrets.
# Variáveis sensíveis DEVEM ficar vazias neste arquivo (template).
# Em produção (VPS, futuro), os secrets são injetados via .env seguro.
# ----------------------------------------------------------------------------

# --- App (Laravel) ---
APP_NAME="Wallet Track"
APP_ENV=local
APP_KEY=
# Gerar com: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file

# PHP CLI server workers (apenas para `php artisan serve`, não usado em prod)
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# --- Logging ---
# Em produção/VPS usar "stderr" (JSON estruturado).
# Em dev local pode ser "stack" (arquivo em storage/logs/laravel.log).
LOG_CHANNEL=stderr
LOG_STACK=single
# ⚠️ Nível de log: o Nutgram (vendor) loga o payload BRUTO do update do Telegram
# em nível debug ("Update processed") e error ("Update failed"). Como é um bot
# financeiro, o payload contém valores/descrições de transações (PII).
# - Dev local: "debug" é OK (somente você vê seus próprios dados).
# - PRODUÇÃO: usar "info" ou superior para NÃO vazar payloads nos logs de
#   produção.
#   (O Dockerfile de produção já fixa LOG_LEVEL=info.)
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null
# Sobrescrever formato do stderr (default: JsonFormatter). Ex.: LineFormatter
# LOG_STDERR_FORMATTER=
# LOG_STDERR_STACKTRACES=false

# --- Database (MariaDB no dev local; SQLite em produção/testes) ---
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wallet_track
DB_USERNAME=wallet
DB_PASSWORD=
DB_ROOT_PASSWORD=

# --- Session / Cache / Queue ---
# Sessions: mantidas em file (bot não usa Laravel Sessions para lógica de
# negócio; sessão conversacional usa Redis Hash diretamente com TTL).
# Cache: migrado para Redis (workers Octane long-lived + I/O de arquivo a cada
# request é antipadrão; Redis já disponível, conexão cache usa db=1,
# prefixo wallet-track-cache-).
# Queue: mantida em database (não há jobs implementados).
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Queue via sync (não há uso de queue no projeto; sem tabelas jobs/failed_jobs/job_batches).
QUEUE_CONNECTION=sync
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# --- Mail (não utilizado pelo bot; mantido pelo skeleton) ---
MAIL_MAILER=log
MAIL_SCHEME=
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS (não utilizado; mantido pelo skeleton) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================================
# Telegram
# ============================================================================
# Token obtido com @BotFather no Telegram.
TELEGRAM_BOT_TOKEN=
# Secret token para validar a origem do webhook (gerar localmente):
#   openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET_TOKEN=
# Lista de chat_ids autorizados (whitelist, uso pessoal). Separar por vírgula.
# Ex.: TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_ALLOWED_CHAT_IDS=
# URL pública do webhook (definida após deploy em VPS ou ngrok em dev).
# Ex.: https://wallet-track.example.com/webhook/telegram
TELEGRAM_WEBHOOK_URL=

# ============================================================================
# DeepSeek (extração de texto → JSON)
# ============================================================================
# Obter em: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============================================================================
# Gemini (OCR multimodal de notas fiscais → JSON)
# ============================================================================
# Obter em (AI Studio): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# Google Sheets (Service Account)
# ============================================================================
# Em desenvolvimento local: caminho para o JSON da Service Account.
# Em produção (VPS, futuro): GOOGLE_SERVICE_ACCOUNT_JSON com o conteúdo inline.
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
# GOOGLE_SERVICE_ACCOUNT_JSON=
# ID da planilha (extraído da URL: /d/<ID>/edit).
GOOGLE_SHEETS_SPREADSHEET_ID=
# Nome da aba principal da planilha.
GOOGLE_SHEETS_SHEET_NAME=Transações
# Nome da aba auxiliar de categorias.
GOOGLE_SHEETS_CATEGORIES_SHEET_NAME=Categorias

# ============================================================================
# Regras de negócio (decisões das Clarificações)
# ============================================================================
# Máximo de tentativas de sync pendente (Sheets) antes de marcar como failed.
SYNC_MAX_RETRIES=3

# ============================================================================
# Cron (DEPRECATED — endpoint HTTP /cron/sync-pending substituído por
# Artisan Schedule em routes/console.php)
# ============================================================================
# CRON_SECRET_TOKEN não é mais consumido por nenhuma rota ativa.
# DEPRECATED: CRON_SECRET_TOKEN=

# ============================================================================
# Vite / Frontend (skeleton)
# ============================================================================
VITE_APP_NAME="${APP_NAME}"
