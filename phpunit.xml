<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <env name="TELEGRAM_ALLOWED_CHAT_IDS" value="5672987197"/>
        <env name="DEEPSEEK_API_KEY" value="test-key"/>
        <env name="DEEPSEEK_BASE_URL" value="https://api.deepseek.com"/>
        <env name="DEEPSEEK_MODEL" value="deepseek-chat"/>
        <env name="DEEPSEEK_TEMPERATURE" value="0.1"/>
        <env name="GEMINI_API_KEY" value="test-gemini-key"/>
        <env name="GEMINI_MODEL" value="gemini-2.5-flash"/>
        <env name="GEMINI_TEMPERATURE" value="0.1"/>
        <env name="GEMINI_TIMEOUT" value="60"/>
        <!-- M5: credenciais Google. Em testes, o gateway real (CloudFirestoreGateway)
             nunca é instanciado — usamos InMemoryFirestoreGateway. Os valores abaixo
             existem apenas para satisfazer config('google.*') sem Undefined index. -->
        <env name="GOOGLE_CLOUD_PROJECT_ID" value="test-project"/>
        <env name="FIRESTORE_DATABASE_ID" value="test-db"/>
        <env name="GOOGLE_SERVICE_ACCOUNT_JSON_PATH" value=""/>
        <env name="GOOGLE_SERVICE_ACCOUNT_JSON" value=""/>
        <!-- M6: config Sheets. O GoogleSheetsGateway real nunca é instanciado
             em testes — usamos InMemorySheetsGateway. Os valores abaixo só
             satisfazem config('google.sheets.*') sem Undefined index. -->
        <env name="GOOGLE_SHEETS_SPREADSHEET_ID" value="test-sheet-id"/>
        <env name="GOOGLE_SHEETS_SHEET_NAME" value="Transações"/>
        <env name="GOOGLE_SHEETS_CATEGORIES_SHEET_NAME" value="Categorias"/>
    </php>
</phpunit>
